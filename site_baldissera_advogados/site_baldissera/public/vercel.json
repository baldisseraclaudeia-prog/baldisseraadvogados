{
  "version": 2,
  "name": "baldissera-advogados",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/sobre", "destination": "/sobre.html" },
    { "source": "/atuacao", "destination": "/areas-de-atuacao.html" },
    { "source": "/advogados", "destination": "/advogados.html" },
    { "source": "/publicacoes", "destination": "/publicacoes.html" },
    { "source": "/contato", "destination": "/contato.html" },
    { "source": "/privacidade", "destination": "/politica-de-privacidade.html" },
    { "source": "/provimento-205", "destination": "/aviso-provimento-205.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains" }
      ]
    }
  ]
}
